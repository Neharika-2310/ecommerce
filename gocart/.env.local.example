# Clerk keys (paste values from your Clerk dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_publishable_key_here
CLERK_SECRET_KEY=your_secret_key_here

# Admin emails (comma-separated) used by `authAdmin`
ADMIN_EMAIL=admin@example.com

# Currency symbol used in the UI
NEXT_PUBLIC_CURRENCY_SYMBOL=$

# Do NOT commit real secrets to git. Copy this file to `.env.local` and fill values.
